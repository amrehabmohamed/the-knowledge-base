# Firebase Web App Config (from Firebase Console)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API Keys
GEMINI_API_KEY=your_gemini_api_key
JINA_API_KEY=your_jina_api_key

# Gemini FileSearch Store
GEMINI_STORE_ID=your_store_id

# Connectors UI feature flag — set to "true" once the connector Cloud Functions
# are deployed in this environment AND CONNECTORS_ENABLED=true is set on the
# functions side. Hides the Connectors nav + /settings/connectors route otherwise.
VITE_CONNECTORS_ENABLED=false
