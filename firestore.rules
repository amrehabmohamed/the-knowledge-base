rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Config: read-only for authenticated users
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Notebooks: owner can CRUD their own
    match /notebooks/{notebookId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      allow get: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      allow list: if request.auth != null
        && request.auth.uid != null;

      allow update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Sources: notebook owner can read/write
      match /sources/{sourceId} {
        allow read, write: if request.auth != null;
      }

      // Sessions: notebook owner can read/write
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null;

        // Messages
        match /messages/{messageId} {
          allow read, write: if request.auth != null;
        }
      }
    }

    // Sessions: collection group query for archive (across all notebooks)
    match /{path=**}/sessions/{sessionId} {
      allow read: if request.auth != null;
    }

    // Response metrics
    match /response_metrics/{metricId} {
      allow read, write: if request.auth != null;
    }
  }
}
